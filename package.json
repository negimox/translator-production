{
  "name": "jitsi-translator-agent",
  "version": "1.0.0",
  "description": "Headless Chromium-based translator agent for Jitsi Meet live audio translation",
  "main": "dist/index.js",
  "scripts": {
    "build": "./node_modules/.bin/tsc",
    "start:index": "npm run build && node dist/index.js",
    "start": "npm run build && node dist/orchestrator-main.js",
    "dev": "./node_modules/.bin/ts-node src/index.ts",
    "lint": "./node_modules/.bin/eslint src/**/*.ts"
  },
  "keywords": [
    "jitsi",
    "translator",
    "webrtc",
    "puppeteer",
    "audio"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "puppeteer": "^22.0.0",
    "express": "^4.18.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.2",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
